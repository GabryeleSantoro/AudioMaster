    "NSBluetoothAlwaysUsageDescription" : {
      "comment" : "Privacy - Bluetooth Always Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AudioMaster benötigt Bluetooth-Zugriff, um gekoppelte Geräte aufzulisten, Verbindungen zu verwalten und Batteriestände anzuzeigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AudioMaster needs Bluetooth access to list paired devices, manage connections, and display battery levels."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AudioMaster necesita acceso Bluetooth para listar dispositivos emparejados, gestionar conexiones y mostrar niveles de batería."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AudioMaster a besoin de l'accès Bluetooth pour lister les appareils appairés, gérer les connexions et afficher les niveaux de batterie."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AudioMaster necessita dell'accesso Bluetooth per elencare i dispositivi associati, gestire le connessioni e mostrare i livelli di batteria."
          }
        }
      }
    },
